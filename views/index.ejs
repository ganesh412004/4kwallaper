<% layout('layout') -%>
<section>
  <h1><%= meta.title || 'Blog' %></h1>
  <% if (typeof query !== 'undefined' && query) { %>
    <p>Search results for "<%= query %>"</p>
  <% } %>
  <% if (posts.length === 0) { %>
    <p>No posts found.</p>
  <% } %>
  <ul class="posts-list">
    <% posts.forEach(function(p){ %>
      <li class="post-item">
        <h2><a href="/post/<%= p.slug %>"><%= p.title %></a></h2>
        <p class="excerpt"><%= p.excerpt %></p>
        <small><%= new Date(p.created_at).toDateString() %></small>
      </li>
    <% }) %>
  </ul>
</section>
